# Copia este archivo como ".env" (sin .example) para probar localmente.
# En Railway estas mismas variables se configuran en Settings → Variables,
# NO en un archivo .env (ese archivo nunca se sube a GitHub).

# Contraseña para entrar al panel /admin
ADMIN_PASSWORD=cambia-esta-clave

# Datos de tu cuenta de Cloudinary (Dashboard → Product Environment Credentials)
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
